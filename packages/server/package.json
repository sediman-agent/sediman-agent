{
  "name": "@sediman/server",
  "version": "0.3.14",
  "type": "module",
  "private": true,
  "bin": {
    "sediman": "./src/cli-bin.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "rpc": "bun run src/index.ts --mode rpc",
    "serve": "bun run src/index.ts --mode api",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "benchmark": "bun scripts/run-benchmarks.ts",
    "benchmark:webbench": "bun scripts/run-benchmarks.ts webbench",
    "benchmark:page-interaction": "bun scripts/run-benchmarks.ts page-interaction",
    "benchmark:mind2web": "bun scripts/run-benchmarks.ts mind2web",
    "benchmark:gaia": "bun scripts/run-benchmarks.ts gaia",
    "benchmark:browsecomp": "bun scripts/run-benchmarks.ts browsecomp"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@sentry/node": "^10.56.0",
    "@slack/socket-mode": "^2.0.3",
    "@slack/web-api": "^7.9.1",
    "cac": "^6.7.14",
    "chalk": "^5.4.1",
    "cloakbrowser": "^0.3.31",
    "discord.js": "^14.18.0",
    "grammy": "^1.36.3",
    "hono": "^4.7.11",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "openai": "^4.103.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.52.0",
    "turndown": "^7.2.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "@types/ink": "^2.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.16",
    "@types/turndown": "^5.0.5",
    "typescript": "~5.8.3"
  }
}
