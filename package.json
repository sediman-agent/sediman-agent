{
  "name": "openskynet",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cargo build --release -p sediman-tui",
    "tui": "cargo run -p sediman-tui --",
    "python": "uv run python -m sediman.rpc_server",
    "backend": "uv run python -m sediman.rpc_server",
    "desktop": "cd app && npm start",
    "app": "cd app && npm start",
    "stop": "pkill -f 'sediman.rpc_server' 2>/dev/null; pkill -f 'sediman-tui' 2>/dev/null; sleep 0.3; rm -f /tmp/sediman-python.sock /tmp/sediman.sock; echo 'Stopped.'",
    "start": "bun run stop && sleep 0.5 && bun run tui",
    "restart": "bun run stop && sleep 0.5 && bun run tui",
    "install-local": "./scripts/install.sh",
    "test": "cargo test -p sediman-tui && uv run pytest",
    "electron": "cd app && npm start",
    "electron:dev": "cd app && npm start"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "electron": "^27.3.11",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "vite-plugin-dts": "^5.0.2"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "tailwind-merge": "^3.6.0"
  }
}
