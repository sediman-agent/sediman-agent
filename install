#!/usr/bin/env bash
set -euo pipefail

# ── Terminator quick installer ──
# Usage: curl -fsSL https://raw.githubusercontent.com/sediman-agent/OpenSkynet/main/install | bash
#   or:  BRANCH=main curl -fsSL ... | bash

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[36m'
DIM='\033[2m'
NC='\033[0m'

info()  { echo -e "  ${GREEN}+${NC} $*"; }
warn()  { echo -e "  ${YELLOW}!${NC} $*"; }
error() { echo -e "  ${RED}X${NC} $*" >&2; }

INSTALL_DIR="$HOME/.terminator"
REPO_URL="https://github.com/sediman-agent/OpenSkynet.git"
BRANCH="${BRANCH:-main}"

has_cmd() { command -v "$1" >/dev/null 2>&1; }

echo ""
echo -e "  ${BOLD}Terminator Installer${NC}"
echo -e "  ${DIM}https://github.com/sediman-agent/OpenSkynet${NC}"
echo ""

# ── Step 1: Prerequisites ──
info "Checking prerequisites..."

if ! has_cmd git; then
    error "git is required. Install it first: https://git-scm.com"
    exit 1
fi

if ! has_cmd uv; then
    warn "uv not found, installing..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
    if ! has_cmd uv; then
        error "Failed to install uv. Install manually: https://docs.astral.sh/uv/"
        exit 1
    fi
fi
info "uv $(uv --version 2>/dev/null | head -1)"

if ! has_cmd cargo; then
    warn "Rust not found, installing..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    export PATH="$HOME/.cargo/bin:$PATH"
    if ! has_cmd cargo; then
        error "Failed to install Rust. Install manually: https://rustup.rs/"
        exit 1
    fi
fi
info "rustc $(rustc --version 2>/dev/null | head -1)"

# ── Step 2: Clone / update repo ──
if [ -d "$INSTALL_DIR/.git" ]; then
    info "Updating Terminator ($BRANCH)..."
    cd "$INSTALL_DIR"
    git fetch origin "$BRANCH" --depth 1
    git reset --hard "origin/$BRANCH" 2>/dev/null || git checkout "$BRANCH"
else
    info "Cloning Terminator ($BRANCH)..."
    rm -rf "$INSTALL_DIR"
    git clone --depth 1 -b "$BRANCH" "$REPO_URL" "$INSTALL_DIR"
    cd "$INSTALL_DIR"
fi

# ── Step 3: Python dependencies ──
info "Installing Python dependencies..."
uv sync --quiet 2>/dev/null || uv sync
info "Python dependencies installed"

# ── Step 4: Build Rust TUI ──
info "Building Terminator TUI (this may take a minute on first run)..."
cargo build --release -p sediman-tui 2>&1 | tail -5
if [ ! -f "target/release/sediman-tui" ]; then
    error "TUI build failed!"
    error "Try manually: cd $INSTALL_DIR && cargo build --release -p sediman-tui"
    exit 1
fi
info "TUI built successfully"

# ── Step 5: Playwright ──
info "Installing Playwright Chromium..."
if uv run playwright install chromium 2>/dev/null; then
    info "Playwright Chromium installed"
else
    warn "Could not install Playwright Chromium automatically."
    warn "Run later: uv run playwright install chromium"
fi

# ── Step 6: Create terminator command ──
mkdir -p "$INSTALL_DIR/bin"
cat > "$INSTALL_DIR/bin/terminator" << 'WRAPPER'
#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "$0")/.." && pwd)"
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
export SEDIMAN_ROOT="$DIR"

pkill -f 'sediman.rpc_server' 2>/dev/null || true
pkill -f 'sediman-tui' 2>/dev/null || true
rm -f /tmp/sediman-python.sock 2>/dev/null || true
sleep 0.5

cd "$DIR"
exec "$DIR/target/release/sediman-tui" "$@"
WRAPPER
chmod +x "$INSTALL_DIR/bin/terminator"

# ── Step 7: Add to PATH ──
add_to_path() {
    local config_file=$1
    local line=$2
    if [ -w "$config_file" ] && ! grep -qF "$INSTALL_DIR/bin" "$config_file" 2>/dev/null; then
        echo "" >> "$config_file"
        echo "# Terminator" >> "$config_file"
        echo "$line" >> "$config_file"
        info "Added to PATH in $config_file"
    fi
}

current_shell=$(basename "${SHELL:-bash}")
case "$current_shell" in
    fish)
        config="$HOME/.config/fish/config.fish"
        mkdir -p "$(dirname "$config")"
        add_to_path "$config" "fish_add_path $INSTALL_DIR/bin"
        ;;
    zsh)
        add_to_path "${ZDOTDIR:-$HOME}/.zshrc" "export PATH=\"$INSTALL_DIR/bin:\$PATH\""
        ;;
    bash)
        add_to_path "$HOME/.bashrc" "export PATH=\"$INSTALL_DIR/bin:\$PATH\""
        ;;
    *)
        add_to_path "$HOME/.profile" "export PATH=\"$INSTALL_DIR/bin:\$PATH\""
        ;;
esac

export PATH="$INSTALL_DIR/bin:$PATH"

# ── Done ──
echo ""
info "Terminator installed!"
echo ""
echo -e "  ${CYAN}terminator${NC}             Launch the TUI"
echo -e "  ${CYAN}terminator --help${NC}      Show options"
echo ""
warn "Run 'source ~/.${current_shell}rc' or open a new terminal, then:"
echo -e "  ${GREEN}export OPENAI_API_KEY=sk-...${NC}"
echo -e "  ${GREEN}terminator${NC}"
echo ""

if [ -n "${GITHUB_ACTIONS-}" ]; then
    echo "$INSTALL_DIR/bin" >> "$GITHUB_PATH"
fi
